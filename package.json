{
    "name": "homebridge-http-motion-sensor",
    "version": "2.0.1",
    "description": "Homebridge plugin for a remote motion sensor based on http",
    "keywords": [
        "arduino",
        "automation",
        "esp8266",
        "homebridge",
        "homebridge-plugin",
        "homekit",
        "http",
        "iot",
        "motion",
        "motion-sensor",
        "motionsensor",
        "sensor",
        "smart-home"
    ],
    "homepage": "https://github.com/lucavb/homebridge-http-motion-sensor#readme",
    "bugs": {
        "url": "https://github.com/lucavb/homebridge-http-motion-sensor/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lucavb/homebridge-http-motion-sensor.git"
    },
    "license": "GPL-3.0",
    "author": {
        "name": "Luca Becker",
        "email": "hello@luca-becker.me",
        "url": "https://luca-becker.me"
    },
    "sideEffects": false,
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "config.schema.json",
        "dist",
        "homebridge-http-motion-sensor.jpg"
    ],
    "scripts": {
        "build": "tsdown",
        "commitlint": "commitlint --edit",
        "cq": "npm run cq:typecheck && npm run cq:eslint && npm run cq:prettier && npm run build",
        "cq:eslint": "eslint . --max-warnings=0",
        "cq:eslint:fix": "eslint . --max-warnings=0 --fix",
        "cq:prettier": "prettier --check .",
        "cq:prettier:fix": "prettier --write .",
        "cq:typecheck": "tsc --noEmit",
        "prepare": "husky",
        "prepublishOnly": "npm run build",
        "publishd": "npm publish --dry-run",
        "release": "semantic-release",
        "release:dry-run": "semantic-release --dry-run",
        "start": "npm run build && homebridge -D -U .tmp -P .",
        "test": "vitest run",
        "test:ci": "vitest run --reporter=verbose",
        "test:integration": "./tests/test.sh --ci",
        "test:watch": "vitest"
    },
    "dependencies": {
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@commitlint/cli": "21.2.0",
        "@commitlint/config-conventional": "21.2.0",
        "@commitlint/types": "21.2.0",
        "@eslint/js": "10.0.1",
        "@semantic-release/commit-analyzer": "13.0.1",
        "@semantic-release/github": "12.0.9",
        "@semantic-release/npm": "13.1.5",
        "@semantic-release/release-notes-generator": "14.1.1",
        "@types/node": "24.13.3",
        "@vitest/eslint-plugin": "1.6.22",
        "conventional-changelog-conventionalcommits": "10.2.1",
        "eslint": "10.6.0",
        "globals": "17.7.0",
        "homebridge": "2.1.0",
        "husky": "9.1.7",
        "jiti": "2.7.0",
        "prettier": "3.9.4",
        "semantic-release": "25.0.5",
        "tsdown": "0.22.4",
        "typescript": "6.0.3",
        "typescript-eslint": "8.63.0",
        "vitest": "4.1.10"
    },
    "peerDependencies": {
        "homebridge": "^1.6.0 || ^2.0.0"
    },
    "engines": {
        "homebridge": "^1.6.0 || ^2.0.0",
        "node": "^22.12.0 || ^24.0.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true,
        "registry": "https://registry.npmjs.org/"
    }
}
