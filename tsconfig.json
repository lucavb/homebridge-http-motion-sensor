{
    "compilerOptions": {
        "target": "ES2025",
        "module": "commonjs",
        "moduleResolution": "bundler",
        "rootDir": "./src",
        "types": ["node"],
        "declaration": true,
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "dist"
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}
