{
    "pluginAlias": "HttpMotionSensorPlatform",
    "pluginType": "platform",
    "singular": false,
    "schema": {
        "type": "object",
        "properties": {
            "name": {
                "title": "Platform Name",
                "type": "string",
                "default": "HTTP Motion Sensor Platform",
                "required": true
            },
            "platform": {
                "title": "Platform Type",
                "type": "string",
                "const": "HttpMotionSensorPlatform",
                "required": true
            },
            "sensors": {
                "title": "Motion Sensors",
                "type": "array",
                "minItems": 1,
                "items": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "title": "Sensor Name",
                            "type": "string",
                            "placeholder": "e.g. Hallway Motion Sensor",
                            "required": true
                        },
                        "port": {
                            "title": "HTTP Port",
                            "type": "string",
                            "pattern": "^(?:[1-9][0-9]{3,4}|[1-6][0-9]{4})$",
                            "placeholder": "e.g. 18089",
                            "required": true,
                            "description": "Port number between 1024 and 65535"
                        },
                        "model": {
                            "title": "Model",
                            "type": "string",
                            "placeholder": "e.g. ESP8266 Motion Sensor"
                        },
                        "serial": {
                            "title": "Serial Number",
                            "type": "string",
                            "placeholder": "e.g. E642011E3ECB"
                        },
                        "bind_ip": {
                            "title": "Bind IP Address",
                            "type": "string",
                            "placeholder": "0.0.0.0",
                            "format": "ipv4"
                        },
                        "reset_timeout": {
                            "title": "Motion Reset Timeout",
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 3600,
                            "placeholder": "11",
                            "description": "Seconds before motion resets to inactive (default: 11)"
                        },
                        "auth": {
                            "title": "Inbound Authentication",
                            "type": "object",
                            "properties": {
                                "mode": {
                                    "title": "Authentication Mode",
                                    "type": "string",
                                    "enum": ["none", "bearer", "basic", "header"],
                                    "default": "none",
                                    "description": "Optional protection for HTTP requests that trigger this sensor"
                                },
                                "token": {
                                    "title": "Bearer Token",
                                    "type": "string",
                                    "placeholder": "Generate a long random string",
                                    "description": "Client must send Authorization: Bearer <token>"
                                },
                                "username": {
                                    "title": "Username",
                                    "type": "string",
                                    "description": "Basic auth username"
                                },
                                "password": {
                                    "title": "Password",
                                    "type": "string",
                                    "description": "Stored in config.json in plaintext"
                                },
                                "header_name": {
                                    "title": "Header Name",
                                    "type": "string",
                                    "default": "X-Api-Key",
                                    "placeholder": "X-Api-Key"
                                },
                                "header_value": {
                                    "title": "Header Value",
                                    "type": "string",
                                    "description": "Expected value for the custom header"
                                }
                            }
                        },
                        "repeater": {
                            "title": "Repeater Endpoints",
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "host": {
                                        "title": "Host",
                                        "type": "string",
                                        "placeholder": "192.168.1.100",
                                        "required": true
                                    },
                                    "port": {
                                        "title": "Port",
                                        "type": "string",
                                        "pattern": "^(?:[1-9]|[1-9][0-9]{1,3}|[1-6][0-9]{4})$",
                                        "placeholder": "80",
                                        "required": true,
                                        "description": "Port number between 1 and 65535"
                                    },
                                    "path": {
                                        "title": "Path",
                                        "type": "string",
                                        "placeholder": "/api/trigger",
                                        "required": true
                                    },
                                    "auth": {
                                        "title": "Authorization Header",
                                        "type": "string",
                                        "placeholder": "Bearer token123"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "form": null,
    "display": null,
    "layout": [
        {
            "type": "flex",
            "flex-flow": "row wrap",
            "items": ["name"]
        },
        {
            "key": "sensors",
            "type": "array",
            "title": "Motion Sensors",
            "description": "Configure one or more HTTP motion sensors",
            "items": [
                "sensors[].name",
                "sensors[].port",
                "sensors[].model",
                "sensors[].serial",
                "sensors[].bind_ip",
                "sensors[].reset_timeout",
                {
                    "type": "section",
                    "title": "Security",
                    "description": "Optional inbound authentication for HTTP trigger requests",
                    "items": [
                        "sensors[].auth.mode",
                        {
                            "key": "sensors[].auth.token",
                            "type": "string",
                            "condition": {
                                "functionBody": "return model.sensors && model.sensors[arrayIndices] && model.sensors[arrayIndices].auth && model.sensors[arrayIndices].auth.mode === 'bearer';"
                            }
                        },
                        {
                            "key": "sensors[].auth.username",
                            "type": "string",
                            "condition": {
                                "functionBody": "return model.sensors && model.sensors[arrayIndices] && model.sensors[arrayIndices].auth && model.sensors[arrayIndices].auth.mode === 'basic';"
                            }
                        },
                        {
                            "key": "sensors[].auth.password",
                            "type": "string",
                            "condition": {
                                "functionBody": "return model.sensors && model.sensors[arrayIndices] && model.sensors[arrayIndices].auth && model.sensors[arrayIndices].auth.mode === 'basic';"
                            }
                        },
                        {
                            "key": "sensors[].auth.header_name",
                            "type": "string",
                            "condition": {
                                "functionBody": "return model.sensors && model.sensors[arrayIndices] && model.sensors[arrayIndices].auth && model.sensors[arrayIndices].auth.mode === 'header';"
                            }
                        },
                        {
                            "key": "sensors[].auth.header_value",
                            "type": "string",
                            "condition": {
                                "functionBody": "return model.sensors && model.sensors[arrayIndices] && model.sensors[arrayIndices].auth && model.sensors[arrayIndices].auth.mode === 'header';"
                            }
                        }
                    ]
                },
                {
                    "key": "sensors[].repeater",
                    "type": "array",
                    "title": "Repeater Endpoints",
                    "description": "Optional: Make additional HTTP requests when motion is detected",
                    "items": [
                        "sensors[].repeater[].host",
                        "sensors[].repeater[].port",
                        "sensors[].repeater[].path",
                        "sensors[].repeater[].auth"
                    ]
                }
            ]
        }
    ]
}
